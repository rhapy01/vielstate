# Postgres (Neon) — required for API, seed, and drizzle push
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# API server
API_PORT=3001

# Frontend (Vite)
PORT=5173
BASE_PATH=/

# Sepolia deploy + ctUSDC test faucet (/api/faucet/usdc)
# Local: put in .ENV at repo root. Vercel/Render: add in hosting dashboard (never commit).
DEPLOYER_PRIVATE_KEY=0x...
# PRIVATE_KEY=0x...  # alias for DEPLOYER_PRIVATE_KEY (0x prefix optional)
# SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# Contract addresses live in lib/addresses/src/address.ts (updated by deploy:sepolia)

# Etherscan verification (lib/contracts verify:sepolia)
# ETHERSCAN_API_KEY=...

# Hosted demo (single URL — API serves built frontend)
# SERVE_WEB=true

# Split frontend/API deploy only (optional; leave empty when SERVE_WEB=true)
# VITE_API_BASE_URL=https://your-api.onrender.com
